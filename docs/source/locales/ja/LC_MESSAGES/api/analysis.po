msgstr ""

#: anno_save_analyzer.analysis.routes.rank_routes:1 of
msgid "route_id でグループ化した効率指標．"
msgstr ""

#: anno_save_analyzer.analysis.persistence.classify_deficit:5
#: anno_save_analyzer.analysis.routes.rank_routes:5
